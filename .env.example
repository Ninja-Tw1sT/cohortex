# Copy to .env and fill in only the cloud backends you use — or run: python setup_env.py
# Ollama (the default backend) needs no key. `.env` is gitignored.

# Cloud backend API keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=

# Optional global overrides (defaults live in configs/backends.yaml)
# COHORTEX_BACKEND=ollama
# COHORTEX_MODEL=phi3:mini
# OLLAMA_BASE_URL=http://localhost:11434
